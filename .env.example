# ===========================================
# 智能算力监测平台 - 环境配置文件
# ===========================================
# 复制此文件为 .env 并修改相应配置
# cp .env.example .env (Linux/Mac)
# copy .env.example .env (Windows)
# ===========================================

# -------------------------------------------
# 数据库配置 (PostgreSQL)
# -------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=computing_power
DB_USER=postgres
DB_PASSWORD=your_secure_password_here

# -------------------------------------------
# 业务配置
# -------------------------------------------
# 工作时段配置 (24小时制)
WORK_HOUR_START=9
WORK_HOUR_END=18

# 使用率阈值配置 (%)
HIGH_USAGE_THRESHOLD=60.0
LOW_USAGE_THRESHOLD=30.0

# 缓存同步间隔 (秒)
# 设备/组织数据缓存刷新频率，默认1小时
CACHE_SYNC_INTERVAL=3600

# -------------------------------------------
# 服务端口配置
# -------------------------------------------
BACKEND_PORT=8001
FRONTEND_PORT=5173

# -------------------------------------------
# Docker 配置 (容器部署时使用)
# -------------------------------------------
# 容器名称
COMPOSE_PROJECT_NAME=computing-power
